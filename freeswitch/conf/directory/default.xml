<include>
  <!--
      PBXClaw Directory
      =================
      Default extensions for alpha.
      Additional extensions are added by the dashboard chat admin
      or install.sh. Each gets its own XML file in this directory.

      Extension 900 (Molty) is always created.
      Extensions 100-199 are for physical phones.
  -->
  <domain name="$${domain}">
    <params>
      <param name="dial-string" value="{^^:sip_invite_domain=${dialed_domain}:presence_id=${dialed_user}@${dialed_domain}}${sofia_contact(*/${dialed_user}@${dialed_domain})}"/>
    </params>

    <groups>
      <group name="default">
        <users>

          <!-- Molty — AI Chief of Staff (always enabled) -->
          <user id="900">
            <params>
              <param name="password" value="CHANGE_ME"/>
              <param name="vm-password" value="900"/>
            </params>
            <variables>
              <variable name="toll_allow" value="domestic,international,local"/>
              <variable name="effective_caller_id_name" value="Molty"/>
              <variable name="effective_caller_id_number" value="900"/>
              <variable name="user_context" value="default"/>
            </variables>
          </user>

          <!-- Example physical phone extension (uncomment and customize) -->
          <!--
          <user id="101">
            <params>
              <param name="password" value="CHANGE_ME"/>
              <param name="vm-password" value="101"/>
            </params>
            <variables>
              <variable name="toll_allow" value="domestic,international,local"/>
              <variable name="effective_caller_id_name" value="Front Desk"/>
              <variable name="effective_caller_id_number" value="101"/>
              <variable name="user_context" value="default"/>
            </variables>
          </user>
          -->

        </users>
      </group>
    </groups>
  </domain>
</include>
