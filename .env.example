# PBXClaw Alpha — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It contains secrets.
#
# Required keys are marked [REQUIRED].
# Optional keys are commented out with defaults shown.

# ═══════════════════════════════════════════
# [REQUIRED] PBXClaw API Key
# ═══════════════════════════════════════════
# Get yours at: https://pbxclaw.com/signup
# This validates your installation and unlocks
# the dashboard. Without it, nothing starts.
PBXCLAW_API_KEY=

# ═══════════════════════════════════════════
# [REQUIRED] Anthropic API Key
# ═══════════════════════════════════════════
# Used for AI voice responses (ext 900 Molty)
# Default model: claude-haiku-4-5
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════
# PBX Engine Configuration
# ═══════════════════════════════════════════
# IP where the PBX engine is running.
# 127.0.0.1 if installed locally by PBXClaw.
PBX_HOST=127.0.0.1
PBX_CONTROL_PORT=8021
PBX_CONTROL_PASSWORD=ClueCon

# ═══════════════════════════════════════════
# Dashboard
# ═══════════════════════════════════════════
DASHBOARD_PORT=4444

# ═══════════════════════════════════════════
# Optional — OpenAI (for TTS)
# ═══════════════════════════════════════════
# If set, uses OpenAI tts-1 for voice responses.
# If not set, falls back to pyttsx3 (local TTS).
# OPENAI_API_KEY=

# ═══════════════════════════════════════════
# Optional — OpenClaw Gateway
# ═══════════════════════════════════════════
# If you run OpenClaw locally, the chat admin
# and voice agent will use it for AI processing.
# OPENCLAW_API_URL=http://127.0.0.1:18789

# ═══════════════════════════════════════════
# Optional — Local LLM Fallback
# ═══════════════════════════════════════════
# For chat admin: Ollama, LM Studio, or any
# OpenAI-compatible local endpoint.
# LOCAL_LLM_URL=http://localhost:1234/v1

# ═══════════════════════════════════════════
# Optional — PSTN / SIP Trunking
# ═══════════════════════════════════════════
# BYO trunk: configure in dashboard Providers page.
# PBXClaw PSTN (coming soon):
# SIGNALWIRE_PROJECT=
# SIGNALWIRE_TOKEN=

# ═══════════════════════════════════════════
# Optional — Advanced
# ═══════════════════════════════════════════
# OPENAI_REALTIME_ENABLED=false
# LOG_LEVEL=INFO
# SIP_PORT_BASE=5091
# RTP_PORT_LOW=20200
# RTP_PORT_HIGH=20400
